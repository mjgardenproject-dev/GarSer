VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_OPENAI_API_KEY=your_openai_api_key
VITE_BOOKING_PHOTOS_BUCKET=booking-photos
VITE_DISABLE_PHOTO_UPLOAD=false
BOOKING_APP_BASE_URL=https://app.example.com
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Configuración de seguridad
VITE_ENABLE_DEBUG_ROUTES=false
VITE_ADMIN_EMAILS=admin@jardineria.com,developer@jardineria.com
