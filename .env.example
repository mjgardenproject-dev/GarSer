# Variables `VITE_*`: visibles en el navegador. No pongas secretos aqui.
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Compatibilidad con proyectos legacy que aun usan la clave anon JWT.
VITE_SUPABASE_ANON_KEY=
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_BOOKING_PHOTOS_BUCKET=booking-photos
VITE_DISABLE_PHOTO_UPLOAD=false
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Variables solo backend / tooling local
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OPENAI_API_KEY=sk-proj-or-sk-live-server-only
BOOKING_APP_BASE_URL=https://app.example.com
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Configuracion de seguridad
VITE_ENABLE_DEBUG_ROUTES=false
